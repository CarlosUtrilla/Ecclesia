{
  "name": "ecclesia",
  "productName": "Ecclesia",
  "version": "0.1.20",
  "description": "Eclesia",
  "main": "./out/main/index.js",
  "author": "Carlos Utrilla",
  "homepage": "https://github.com/CarlosUtrilla/Ecclesia",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "release": "bash scripts/release.sh",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev --watch",
    "build": "npm run typecheck && electron-vite build",
    "build:ci": "electron-vite build",
    "postinstall": "electron-builder install-app-deps && npx prisma generate",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:local": "electron-vite build && electron-builder --mac --dir",
    "build:ci:mac": "electron-vite build && electron-builder --mac",
    "build:ci:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "sync": "git pull && npx prisma migrate dev",
    "seed": "npx ts-node prisma/seed.ts",
    "bible:reset-schema": "sqlite3 prisma/dev.db \"DELETE FROM BibleVerses; DELETE FROM BibleSchema; DELETE FROM sqlite_sequence WHERE name='BibleVerses' OR name='BibleSchema';\" && rm -f ~/Library/Application\\ Support/ecclesia/bibles/.schema-initialized && echo '✅ Tablas de biblia vaciadas, IDs reiniciados y marcador eliminado'",
    "db:reset": "rm -f ~/Library/Application\\ Support/ecclesia/dev.db && echo '✅ Base de datos local borrada. Arranca la app para recrear.'",
    "db:backup": "cp ~/Library/Application\\ Support/ecclesia/dev.db ~/Library/Application\\ Support/ecclesia/backups/manual-$(date +%Y%m%d-%H%M%S).db && echo '✅ Backup manual creado'",
    "db:inspect": "sqlite3 ~/Library/Application\\ Support/ecclesia/dev.db"
  },
