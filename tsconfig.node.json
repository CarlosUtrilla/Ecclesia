{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "electron/main/**/*",
    "electron/preload/**/*",
    "database/**/*"
  ],
  "exclude": [
    "node_modules",
    "out",
    "dist",
    "**/.vite",
    "**/generated"
  ],
  "compilerOptions": {
    "composite": true,
    "experimentalDecorators": true,
    "types": [
      "electron-vite/node"
    ],
    "skipLibCheck": true,
    "incremental": true
  }
}