// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Song {
  id        Int      @id @default(autoincrement())
  title     String
  author    String?
  copyright String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lyrics    Lyrics[]
  fullText  String   @default("") // Campo para búsqueda de texto completo
}

model Lyrics {
  id        Int      @id @default(autoincrement())
  content   String
  song      Song     @relation(fields: [songId], references: [id])
  songId    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SettingOptions {
  SALES_DAILY   @map("goals.daily")
  SALES_MONTHLY @map("goals.monthly")
}

model Setting {
  id        Int            @id @default(autoincrement())
  key       SettingOptions @unique
  value     String // lo guardas como JSON string si necesitas objetos
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}
