# OAuth de Google Drive para sincronización (nivel aplicación)
# Crea un OAuth Client en Google Cloud Console y usa el redirect URI:
# http://127.0.0.1:53682/oauth2callback

GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# Alias opcionales compatibles
# ECCLESIA_GOOGLE_DRIVE_CLIENT_ID=
# ECCLESIA_GOOGLE_DRIVE_CLIENT_SECRET=
